# Align R2's gripper to the KFS cube on an adjacent block, then (optionally)
# trigger the pick sequence. Called by the forest executor when the planner
# emits VISUAL_SERVO_BLOCK.

# Block height enum values (block_height field)
uint8 HEIGHT_A=0   # 200 mm
uint8 HEIGHT_B=1   # 400 mm
uint8 HEIGHT_C=2   # 600 mm

# Goal
int32 block_id
uint8 block_height
---
# Result
bool success
float32 final_offset_mm
string message
---
# Feedback
float32 current_offset_mm
string state
